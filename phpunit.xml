<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <!--
            I test girano su PostgreSQL, lo stesso motore della produzione: il
            codebase usa funzionalità pg-specifiche che SQLite non supporta
            (gen_random_uuid() come default colonna, CHECK constraint via
            DB::statement, ILIKE, lower(email)). DB dedicato: atheneum_test_db.
            La password NON è qui (segreto): in locale arriva da .env (gitignored),
            in CI dalle env reali del runner. Questi <env> sono non-forced, quindi
            le env del runner CI hanno precedenza (vedi .github/workflows/tests.yml).
            pgvector non è richiesto: la migrazione documents_rag degrada con
            try/catch e nemmeno la produzione ha l'estensione installata.
        -->
        <env name="DB_CONNECTION" value="pgsql"/>
        <env name="DB_HOST" value="127.0.0.1"/>
        <env name="DB_PORT" value="5433"/>
        <env name="DB_DATABASE" value="atheneum_test_db"/>
        <env name="DB_USERNAME" value="atheneum"/>
        <env name="DB_URL" value=""/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
    </php>
</phpunit>
